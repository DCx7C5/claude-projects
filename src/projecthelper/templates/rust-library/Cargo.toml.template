[package]
name = "{{ project_name }}"
version = "0.1.0"
edition = "{{ rust_edition }}"
description = "{{ project_description }}"
authors = ["{{ author_name }} <{{ author_email }}>"]
license = "{{ license }}"
readme = "README.md"
repository = "https://github.com/{{ author_name }}/{{ project_name }}"
documentation = "https://docs.rs/{{ project_name }}"
keywords = ["library", "rust"]
categories = ["development-tools"]

[lib]
name = "{{ project_name | replace('-', '_') }}"
path = "src/lib.rs"

[dependencies]
thiserror = "1.0"

[dev-dependencies]
criterion = "0.5"

[[bench]]
name = "benchmarks"
harness = false