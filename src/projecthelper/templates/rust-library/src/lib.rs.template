#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_hello() {
        assert_eq!(hello("World"), "Hello, World!");
        assert_eq!(hello("Rust"), "Hello, Rust!");
    }

    #[test]
    fn test_process_input_valid() {
        let result = process_input("test");
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), "Processed: test");
    }

    #[test]
    fn test_process_input_empty() {
        let result = process_input("");
        assert!(result.is_err());
        match result.unwrap_err() {
            {{ project_name | title | replace('-', '') }}Error::InvalidInput(msg) => {
                assert_eq!(msg, "Input cannot be empty");
            }
            _ => panic!("Wrong error type"),
        }
    }

    #[test]
    fn test_struct_functionality() {
        let mut item = {{ project_name | title | replace('-', '') }}::new("test".to_string(), 5);

        assert_eq!(item.name(), "test");
        assert_eq!(item.value(), 5);
        assert_eq!(item.calculate(), 10);

        item.set_value(10);
        assert_eq!(item.value(), 10);
        assert_eq!(item.calculate(), 20);
    }
}