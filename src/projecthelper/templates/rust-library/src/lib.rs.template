pub fn process_input(input: &str) -> Result<String> {
    if input.is_empty() {
        return Err({{ project_name | title | replace('-', '') }}Error::InvalidInput(
            "Input cannot be empty".to_string()
        ));
    }

    Ok(format!("Processed: {}", input))
}

