## Quick Start

```rust
use {{ project_name | replace('-', '_') }}::*;

fn main() {
    // Basic greeting
    let greeting = hello("World");
    println!("{}", greeting); // "Hello, World!"

    // Error handling example
    match process_input("some input") {
        Ok(result) => println!("Success: {}", result),
        Err(e) => eprintln!("Error: {}", e),
    }

    // Using the main struct
    let mut item = {{ project_name | title | replace('-', '') }}::new("example".to_string(), 42);
